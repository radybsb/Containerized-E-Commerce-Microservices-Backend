@using Frontend.Services
@using Frontend.Models

@page "/customers"
@inject ApiService Api

<h3>Customers</h3>

@if (isLoading)
{
  <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
  <p style="color: red;">Error: @errorMessage</p>
}
else if (customers == null || !customers.Any())
{
  <p>No customers found.</p>
  <p>Come back later.</p>
}
else
{
  <div class="container">
    <table class="table">
      <thead>
        <tr>
          <th>Customer ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone Number</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var customer in customers)
        {
          <tr>
            <td>@customer.Id</td>
            <td>@customer.Name</td>
            <td>@customer.Email</td>
            <td>@customer.PhoneNumber</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

<h4>Add a Customer</h4>
<div class="container">
  <form @onsubmit="HandleAddCustomer">
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="customerName">Customer Name</label>
      <input type="text" class="form-control" id="customerName" @bind="newCustomer.Name" placeholder="Enter customer name" required>
    </div>
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="customerEmail">Email</label>
      <input type="email" class="form-control" id="customerEmail" @bind="newCustomer.Email" placeholder="Enter email address" required>
    </div>
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="customerPhone">Phone Number</label>
      <input type="tel" class="form-control" id="customerPhone" @bind="newCustomer.PhoneNumber" placeholder="Enter phone number" required>
    </div>
    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">Add</button>
    @if (!string.IsNullOrEmpty(successMessage))
    {
      <p style="color: green; margin-top: 10px;">@successMessage</p>
    }
  </form>
</div>

@code {
  private List<CustomerDto> customers;
  private CustomerDto newCustomer = new();
  private string errorMessage = "";
  private string successMessage = "";
  private bool isLoading = true;
  private bool isSubmitting = false;

  protected override async Task OnInitializedAsync()
  {
    await LoadCustomers();
  }

  private async Task LoadCustomers()
  {
    isLoading = true;
    errorMessage = "";
    try
    {
      customers = await Api.GetCustomersAsync();
    }
    catch (Exception ex)
    {
      errorMessage = ex.Message;
    }
    finally
    {
      isLoading = false;
    }
  }

  private async Task HandleAddCustomer()
  {
    isSubmitting = true;
    successMessage = "";
    errorMessage = "";

    try
    {
      await Api.CreateCustomerAsync(newCustomer);
      successMessage = "Customer added successfully!";
      newCustomer = new(); // Reset the form
      await Task.Delay(1500);
      successMessage = "";
      await LoadCustomers(); // Reload the customers list
    }
    catch (Exception ex)
    {
      errorMessage = $"Error adding customer: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }
}
