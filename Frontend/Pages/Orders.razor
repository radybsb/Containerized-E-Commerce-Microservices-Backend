@using Frontend.Services
@using Frontend.Models

@page "/orders"
@inject ApiService Api

<h3>Orders</h3>

@if (isLoading)
{
  <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
  <p style="color: red;">Error: @errorMessage</p>
}
else if (orders == null || !orders.Any())
{
  <p>No orders found.</p>
  <p>Come back later.</p>
}
else
{
  <div class="container">
    <table class="table">
      <thead>
        <tr>
          <th>Customer ID</th>
          <th>Product ID</th>
          <th>Quantity</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var order in orders)
        {
          <tr>
            <td>@order.CustomerId</td>
            <td>@order.ProductId</td>
            <td>@order.Quantity</td>
            <td>$@order.Total</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

<h4>Add an Order</h4>
<div class="container">
  <form @onsubmit="HandleAddOrder">
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="customerId">Customer ID</label>
      <input type="number" class="form-control" id="customerId" @bind="newOrder.CustomerId" placeholder="Enter customer ID" required>
    </div>
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="productId">Product ID</label>
      <input type="number" class="form-control" id="productId" @bind="newOrder.ProductId" placeholder="Enter product ID" required>
    </div>
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="orderQuantity">Quantity</label>
      <input type="number" class="form-control" id="orderQuantity" @bind="newOrder.Quantity" placeholder="Enter quantity" required>
    </div>
    <div class="form-group" style="margin-bottom: 10px;">
      <label for="orderTotal">Total</label>
      <input type="number" step="0.01" class="form-control" id="orderTotal" @bind="newOrder.Total" placeholder="Enter total price" required>
    </div>
    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">Add</button>
    @if (!string.IsNullOrEmpty(successMessage))
    {
      <p style="color: green; margin-top: 10px;">@successMessage</p>
    }
  </form>
</div>

@code {
  private List<OrderDto> orders;
  private OrderDto newOrder = new();
  private string errorMessage = "";
  private string successMessage = "";
  private bool isLoading = true;
  private bool isSubmitting = false;

  protected override async Task OnInitializedAsync()
  {
    await LoadOrders();
  }

  private async Task LoadOrders()
  {
    isLoading = true;
    errorMessage = "";
    try
    {
      orders = await Api.GetOrdersAsync();
    }
    catch (Exception ex)
    {
      errorMessage = ex.Message;
    }
    finally
    {
      isLoading = false;
    }
  }

  private async Task HandleAddOrder()
  {
    isSubmitting = true;
    successMessage = "";
    errorMessage = "";

    try
    {
      await Api.CreateOrderAsync(newOrder);
      successMessage = "Order added successfully!";
      newOrder = new(); // Reset the form
      await Task.Delay(1500);
      successMessage = "";
      await LoadOrders(); // Reload the orders list
    }
    catch (Exception ex)
    {
      errorMessage = $"Error adding order: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }
}
